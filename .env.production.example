# Copy to .env.production and fill in.
# Never commit .env.production.

# Long random string, e.g. openssl rand -hex 32
AUTH_SECRET=

# From Cloudflare Zero Trust → Networks → Tunnels → <your tunnel> → Install connector
TUNNEL_TOKEN=

# Optional — if unset, password reset links are logged to server stdout
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
